<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			 xmlns:dataCollectors="clr-namespace:CCSSDomain.DataCollectors;assembly=CCSSDomain"
			 x:Class="ScoutingApp.Views.DataTemplates.MultiIntegerDataFieldInputView"
			 x:DataType="dataCollectors:MultiIntegerInputDataCollector">

	<VerticalStackLayout>

		<Label
			Text="{Binding Path=Label}"
			HorizontalTextAlignment="Center"
			VerticalTextAlignment="Center"/>

		<Grid
			ColumnSpacing="1">

			<Grid.ColumnDefinitions>
				<ColumnDefinition/>
				<ColumnDefinition/>
				<ColumnDefinition/>
				<ColumnDefinition/>
				<ColumnDefinition/>
			</Grid.ColumnDefinitions>

			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<Button
				Text="-1"
				Grid.Column="0"
				Clicked="DecrementButton_OnClicked"/>

			<Label
				Text="{Binding Path=Value}"
				HorizontalTextAlignment="Center"
				VerticalTextAlignment="Center"
				Grid.Column="1"/>

			<Button
				Text="+1"
				Grid.Column="2"
				Clicked="IncrementOneButton_OnClick"/>

			<Button
				Text="+5"
				Grid.Column="3"
				Clicked="IncrementFiveButton_OnClick"/>

			<Button
				Text="+10"
				Grid.Column="4"
				Clicked="IncrementTenButton_OnClick"/>

		</Grid>

	</VerticalStackLayout>

</ContentView>